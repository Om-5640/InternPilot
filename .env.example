# ── Database ──────────────────────────────────────────────────────────────────
# asyncpg URL — must point to a PostgreSQL 17 instance with the pgvector extension.
# Default matches the Docker run command in README.md (host port 5433).
DATABASE_URL=postgresql+asyncpg://postgres:testpass@localhost:5433/internpilot

# ── JWT ───────────────────────────────────────────────────────────────────────
# Generate a real secret: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=change-me-to-a-long-random-secret-at-least-32-chars
JWT_ALG=HS256
ACCESS_TTL=3600      # seconds — access token lifetime  (default 1 h)
REFRESH_TTL=604800   # seconds — refresh token lifetime (default 7 d)

# ── Google OAuth (optional) ───────────────────────────────────────────────────
# Required only for Google Sign-In. Leave empty to disable that provider.
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

# ── GitHub (optional) — raises public API rate limit from 60 to 5000 req/hr ──
GITHUB_TOKEN=

# ── LLM providers — at least one key required for generation features ─────────
# Chain: Gemini 2.5 Flash → Groq Llama 3.3 70B → OpenRouter → DeepSeek → Ollama.
# A provider with an empty key is silently skipped; no restart needed.
# Groq free tier is sufficient for local development.
GEMINI_API_KEY=
GROQ_API_KEY=
OPENROUTER_API_KEY=

# ── Optional LLM backstops ────────────────────────────────────────────────────
DEEPSEEK_API_KEY=
OLLAMA_URL=          # e.g. http://localhost:11434  — empty string = disabled

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins. Include the frontend dev server port.
CORS_ORIGINS=http://localhost:3000,http://localhost:5173,http://localhost:8080
