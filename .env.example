# ── Database ──────────────────────────────────────────────────────────────────
# asyncpg URL — must point to a PostgreSQL instance with the pgvector extension.
#
# Local (Docker Compose):
#   DATABASE_URL=postgresql+asyncpg://postgres:testpass@localhost:5432/internpilot
#
# Supabase / Neon / Render cloud (SSL required — append ?ssl=require):
#   DATABASE_URL=postgresql+asyncpg://postgres:<pw>@<host>:5432/internpilot?ssl=require
#
# ⚠ pgvector must be enabled on the database before running migrations.
#   Supabase: enabled by default.
#   Neon: enable via dashboard → Extensions → vector.
#   Self-hosted: run "CREATE EXTENSION IF NOT EXISTS vector;" as superuser.
DATABASE_URL=postgresql+asyncpg://postgres:testpass@localhost:5432/internpilot

# ── JWT ───────────────────────────────────────────────────────────────────────
# Generate a real secret: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=change-me-to-a-long-random-secret-at-least-32-chars
JWT_ALG=HS256
ACCESS_TTL=3600      # seconds — access token lifetime  (default 1 h)
REFRESH_TTL=604800   # seconds — refresh token lifetime (default 7 d)

# ── Google OAuth (optional) ───────────────────────────────────────────────────
# Required only for Google Sign-In. Leave empty to disable that provider.
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

# ── GitHub (optional) — raises public API rate limit from 60 to 5000 req/hr ──
GITHUB_TOKEN=

# ── LLM providers — at least one key required for generation features ─────────
# Chain: Gemini 2.5 Flash → Groq Llama 3.3 70B → Mistral → OpenRouter → DeepSeek → Ollama.
# A provider with an empty key is silently skipped; no restart needed.
# Groq free tier is sufficient for local development.
# Mistral recommended for cover letters (more human-like writing style).
GEMINI_API_KEY=
GROQ_API_KEY=
MISTRAL_API_KEY=     # Register at https://console.mistral.ai — free tier available
OPENROUTER_API_KEY=

# ── Optional LLM backstops ────────────────────────────────────────────────────
DEEPSEEK_API_KEY=
OLLAMA_URL=          # e.g. http://localhost:11434  — empty string = disabled

# ── Job board sources — domain-agnostic (optional) ───────────────────────────
# USAJobs: federal government internships across ALL fields (engineering, science,
# finance, medicine, etc.). Register free at https://developer.usajobs.gov/
USAJOBS_API_KEY=
USAJOBS_EMAIL=       # the email address you used to register with USAJobs

# Adzuna: private-sector aggregator, all industries, 250 free API calls/month.
# Register free at https://developer.adzuna.com/
ADZUNA_APP_ID=
ADZUNA_APP_KEY=
ADZUNA_COUNTRY=in    # us | gb | de | au | in | ca

# JSearch (RapidAPI): aggregates LinkedIn + Indeed + Glassdoor, keyword search.
# 200 free requests/month. Register at https://rapidapi.com → search "JSearch"
# → subscribe to "letscrape-6bRBa3QguO5/jsearch" → copy the X-RapidAPI-Key.
JSEARCH_API_KEY=

# ── Pipeline settings ─────────────────────────────────────────────────────────
# When true (default) only ingest postings whose title contains "intern/internship".
INTERNSHIP_FILTER=true

# ── Firecrawl — research program portal scraper (optional) ───────────────────
# Scrapes Tier 1 research portals (SURF, DAAD RISE, MITACS, NSF REU, JNCASR, etc.)
# Register free at https://firecrawl.dev — 500 scrapes/month on free tier.
FIRECRAWL_API_KEY=

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins. Include the frontend dev server port.
CORS_ORIGINS=http://localhost:3000,http://localhost:5173,http://localhost:8080
