# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/internpilot

# ── JWT ───────────────────────────────────────────────────────────────────────
JWT_SECRET=change-me-to-a-long-random-secret
JWT_ALG=HS256
ACCESS_TTL=3600        # seconds (1 h)
REFRESH_TTL=604800     # seconds (7 d)

# ── Google OAuth ──────────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

# ── GitHub (optional) — raises rate limit from 60 to 5000 req/hr ─────────────
GITHUB_TOKEN=

# ── LLM providers (at least one required) ────────────────────────────────────
GEMINI_API_KEY=
GROQ_API_KEY=
OPENROUTER_API_KEY=

# ── Optional LLM backstops ────────────────────────────────────────────────────
DEEPSEEK_API_KEY=
OLLAMA_URL=          # e.g. http://localhost:11434

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins
CORS_ORIGINS=http://localhost:3000
